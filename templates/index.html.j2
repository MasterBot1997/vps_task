            </div>

            <section class="package-row">
                <div class="package">Django REST<br><small>Build APIs!</small></div>
                <div class="package">django-filter<br><small>Filter queries!</small></div>
                <div class="package">django-crispy<br><small>Pretty forms!</small></div>
                <div class="package">django-allauth<br><small>Social login!</small></div>
                <div class="package">Wagtail CMS<br><small>Content magic!</small></div>
            </section>

            <section class="guestbook">
                <div>PLEASE SIGN OUR GUESTBOOK!</div>
                <div class="book">📖 We ♥ Visitors!</div>
                <button>CLICK HERE TO SIGN!</button>
            </section>

            <section class="badges">
                <div>Hosted by PYTHOHOST</div>
                <div>W3C HTML 4.01 ✓</div>
                <div>W3C CSS ✓</div>
                <div>Django Powered</div>
                <div>Built with Python</div>
            </section>

            <section class="counter">
                <p>YOU ARE VISITOR NUMBER:</p>
                <div class="digits">001234567</div>
                <div class="come-back">>>> COME BACK SOON! <<<</div>
