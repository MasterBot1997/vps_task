<?php
{% if path_diagnostics_basic_auth %}
$expectedUser = '{{ path_diagnostics_user }}';
$expectedPassword = '{{ path_diagnostics_password }}';
$user = $_SERVER['PHP_AUTH_USER'] ?? '';
$password = $_SERVER['PHP_AUTH_PW'] ?? '';

if (!hash_equals($expectedUser, $user) || !hash_equals($expectedPassword, $password)) {
    header('WWW-Authenticate: Basic realm="OpenCart path diagnostics"');
    http_response_code(401);
    echo 'Authentication required';
    exit;
}
{% endif %}

$pageName = '{{ page_name }}';
$currentPath = realpath(__DIR__);
$mysqli = new mysqli('{{ mysql_host }}', '{{ db_user }}', '{{ db_password }}', '{{ db_name }}', {{ mysql_port }});

if ($mysqli->connect_errno) {
    http_response_code(500);
    echo 'Database connection failed: ' . $mysqli->connect_error;
    exit;
}

$mysqli->query("CREATE TABLE IF NOT EXISTS {{ db_prefix }}path_guard (
  id INT PRIMARY KEY AUTO_INCREMENT,
  page_name VARCHAR(100) NOT NULL UNIQUE,
  expected_path TEXT NOT NULL,
  created_at DATETIME NOT NULL,
  updated_at DATETIME NOT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4");

$stmt = $mysqli->prepare("SELECT expected_path FROM {{ db_prefix }}path_guard WHERE page_name = ?");
$stmt->bind_param('s', $pageName);
$stmt->execute();
$result = $stmt->get_result();
$row = $result->fetch_assoc();

if (!$row) {
    $insert = $mysqli->prepare("INSERT INTO {{ db_prefix }}path_guard (page_name, expected_path, created_at, updated_at) VALUES (?, ?, NOW(), NOW())");
    $insert->bind_param('ss', $pageName, $currentPath);
    $insert->execute();
    echo 'OK. Stored expected path: ' . htmlspecialchars($currentPath, ENT_QUOTES, 'UTF-8');
    exit;
}

$expectedPath = $row['expected_path'];

if (!hash_equals($expectedPath, $currentPath)) {
    http_response_code(500);
    echo 'Path mismatch. Expected: ' . htmlspecialchars($expectedPath, ENT_QUOTES, 'UTF-8') . ' Current: ' . htmlspecialchars($currentPath, ENT_QUOTES, 'UTF-8');
    exit;
}

$update = $mysqli->prepare("UPDATE {{ db_prefix }}path_guard SET updated_at = NOW() WHERE page_name = ?");
$update->bind_param('s', $pageName);
$update->execute();

echo 'OK. Path: ' . htmlspecialchars($currentPath, ENT_QUOTES, 'UTF-8');
